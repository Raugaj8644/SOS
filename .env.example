# ── CERP Environment Variables ────────────────────────────────────────────────
# DEV:  copy to .env  (never commit .env)
# PROD: paste into Railway / Vercel environment variable settings

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# URL of the deployed frontend — used for CORS whitelist
# e.g. https://cerp.vercel.app
APP_URL=https://your-frontend.vercel.app

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection parameters
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-supabase-db-password
DB_SSL_REJECT_UNAUTHORIZED=false    # required for Supabase & Railway Postgres

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Upstash Console → Redis → Details → REST / Redis URL
REDIS_HOST=your-region.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password
REDIS_TLS=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate-a-64-char-random-hex
JWT_REFRESH_SECRET=generate-a-different-64-char-random-hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── File Storage (Cloudflare R2) ──────────────────────────────────────────────
# Cloudflare → R2 → Manage R2 API Tokens
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=cerp-media
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key
S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_URL=https://pub-xxxx.r2.dev   # if bucket is public

# ── Firebase Admin SDK (push notifications) ───────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — set these in Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api.railway.app
NEXT_PUBLIC_WS_URL=wss://your-api.railway.app

# Firebase Web App config
# Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BH...

# ── Local dev only ────────────────────────────────────────────────────────────
# (override above for local development)
# NODE_ENV=development
# DB_HOST=localhost
# DB_PORT=5433
# REDIS_HOST=localhost
# REDIS_PORT=6379
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_WS_URL=ws://localhost:4000
