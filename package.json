{
  "name": "cerp",
  "version": "0.1.0",
  "private": true,
  "description": "Community Emergency Response Platform",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev":          "turbo run dev",
    "build":        "turbo run build",
    "test":         "turbo run test",
    "lint":         "turbo run lint",
    "type-check":   "turbo run type-check",
    "db:migrate":   "pnpm --filter api run db:migrate",
    "db:generate":  "pnpm --filter api run db:generate",
    "db:rollback":  "pnpm --filter api run db:rollback",
    "docker:dev":   "docker compose up -d",
    "docker:down":  "docker compose down",
    "docker:prod":  "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "clean":        "turbo run build --force"
  },
  "devDependencies": {
    "turbo":        "^1.13.3",
    "@types/node":  "^20.14.9",
    "typescript":   "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
